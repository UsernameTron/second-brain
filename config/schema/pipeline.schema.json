{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pipeline Configuration Schema",
  "description": "Validates config/pipeline.json \u2014 all Phase 2 thresholds and configuration values",
  "type": "object",
  "required": [
    "classifier",
    "extraction",
    "wikilink",
    "promotion",
    "retry",
    "leftProposal",
    "filename",
    "slippage"
  ],
  "properties": {
    "classifier": {
      "type": "object",
      "required": [
        "stage1ConfidenceThreshold",
        "stage2ConfidenceThreshold",
        "sonnetEscalationThreshold",
        "sonnetAcceptThreshold",
        "shortInputChars"
      ],
      "properties": {
        "stage1ConfidenceThreshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "stage2ConfidenceThreshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "sonnetEscalationThreshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "sonnetAcceptThreshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "shortInputChars": {
          "type": "integer",
          "minimum": 1
        },
        "llm": {
          "type": "object",
          "required": [
            "provider",
            "localEndpoint",
            "localModel"
          ],
          "properties": {
            "provider": {
              "type": "string",
              "enum": [
                "anthropic",
                "local"
              ]
            },
            "localEndpoint": {
              "type": "string",
              "minLength": 1
            },
            "localModel": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "extraction": {
      "type": "object",
      "required": [
        "confidenceAccept",
        "confidenceLowConfidence",
        "chunkSize",
        "chunkOverlap",
        "oversizeThresholdBytes",
        "oversizeThresholdMessages"
      ],
      "properties": {
        "confidenceAccept": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "confidenceLowConfidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "chunkSize": {
          "type": "integer",
          "minimum": 1
        },
        "chunkOverlap": {
          "type": "integer",
          "minimum": 0
        },
        "oversizeThresholdBytes": {
          "type": "integer",
          "minimum": 1
        },
        "oversizeThresholdMessages": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "wikilink": {
      "type": "object",
      "required": [
        "relevanceThreshold",
        "maxSuggestions",
        "minSuggestions",
        "candidatePoolSize"
      ],
      "properties": {
        "relevanceThreshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "maxSuggestions": {
          "type": "integer",
          "minimum": 1
        },
        "minSuggestions": {
          "type": "integer",
          "minimum": 1
        },
        "candidatePoolSize": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "promotion": {
      "type": "object",
      "required": [
        "batchCapMax",
        "batchCapMin",
        "archiveEntriesThreshold",
        "archiveSizeThresholdKB",
        "proposalArchiveThreshold"
      ],
      "properties": {
        "batchCapMax": {
          "type": "integer",
          "minimum": 1
        },
        "batchCapMin": {
          "type": "integer",
          "minimum": 1
        },
        "archiveEntriesThreshold": {
          "type": "integer",
          "minimum": 1
        },
        "archiveSizeThresholdKB": {
          "type": "integer",
          "minimum": 1
        },
        "proposalArchiveThreshold": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "retry": {
      "type": "object",
      "required": [
        "delayMinutes",
        "maxAttempts"
      ],
      "properties": {
        "delayMinutes": {
          "type": "integer",
          "minimum": 1
        },
        "maxAttempts": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "leftProposal": {
      "type": "object",
      "required": [
        "autoArchiveDays"
      ],
      "properties": {
        "autoArchiveDays": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "filename": {
      "type": "object",
      "required": [
        "maxLength",
        "haikuWordRange"
      ],
      "properties": {
        "maxLength": {
          "type": "integer",
          "minimum": 1
        },
        "haikuWordRange": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "minItems": 2,
          "maxItems": 2
        }
      },
      "additionalProperties": false
    },
    "slippage": {
      "type": "object",
      "required": [
        "staleDays",
        "excludeProjects",
        "maxProjects"
      ],
      "properties": {
        "staleDays": {
          "type": "integer",
          "minimum": 1
        },
        "excludeProjects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "maxProjects": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "thresholds": {
      "type": "object",
      "properties": {
        "haikuTimeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 30000
        },
        "wikilinkTokenBudget": {
          "type": "integer",
          "minimum": 64,
          "maximum": 8192
        }
      },
      "additionalProperties": false
    },
    "memory": {
      "type": "object",
      "properties": {
        "echoThreshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "semantic": {
          "type": "object",
          "properties": {
            "model": {
              "type": "string",
              "enum": [
                "voyage-4-lite"
              ],
              "default": "voyage-4-lite"
            },
            "threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "default": 0.72
            },
            "recencyDecay": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "default": 0.2
            },
            "rrfK": {
              "type": "integer",
              "minimum": 1,
              "default": 60
            },
            "candidatesPerSource": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 20
            },
            "embedBatchSize": {
              "type": "integer",
              "minimum": 1,
              "maximum": 128,
              "default": 128
            },
            "timeoutMs": {
              "type": "integer",
              "minimum": 100,
              "default": 3000
            },
            "degradedModeMinutes": {
              "type": "integer",
              "minimum": 1,
              "default": 15
            },
            "embeddingDim": {
              "type": "integer",
              "enum": [
                1024
              ],
              "default": 1024
            }
          },
          "required": [
            "model",
            "threshold",
            "recencyDecay",
            "rrfK"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
