    "test:uat": "CI= npx jest --forceExit test/uat/",
    "test:uat:ci": "jest --forceExit test/uat/",
    "license-check": "license-checker --production --onlyAllow 'MIT;ISC;Apache-2.0;BSD-2-Clause;BSD-3-Clause;CC0-1.0'",
    "prepare": "git config core.hooksPath hooks"
  },
  "keywords": [],
  "author": "C Pete Conner",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "chokidar": "^3.6.0",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "minisearch": "^7.2.0",
    "voyageai": "0.2.1"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      ".claude/worktrees"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "ajv": "^8.18.0",
    "eslint": "^10.2.1",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-n": "^17.24.0",
    "jest": "^30.3.0",
    "license-checker": "^25.0.1",
